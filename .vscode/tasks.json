{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "frontend: npm start",
      "type": "shell",
      "command": "npm",
      "args": ["start"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Application bundle generation complete|bundle generation failed"
        }
      }
    }
  ]
}
